generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  resumes      Resume[]
  jobPostings  JobPosting[]
  applications Application[]
}

model Resume {
  id               String   @id @default(cuid())
  userId           String
  title            String
  originalFileName String
  originalFileType String
  storagePath      String
  rawText          String   @db.Text
  structuredData   Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions     ResumeVersion[]
  analyses     AIAnalysis[]
  applications Application[]

  @@index([userId])
}

model JobPosting {
  id             String   @id @default(cuid())
  userId         String
  title          String?
  company        String?
  rawText        String   @db.Text
  structuredData Json
  createdAt      DateTime @default(now())

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions     ResumeVersion[]
  analyses     AIAnalysis[]
  applications Application[]

  @@index([userId])
}

model AIAnalysis {
  id              String   @id @default(cuid())
  resumeId        String
  jobPostingId    String
  matchScore      Int
  atsScore        Int
  matchingSkills  Json
  missingSkills   Json
  keywordAnalysis Json
  suggestions     Json
  createdAt       DateTime @default(now())

  resume         Resume          @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobPosting     JobPosting      @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  resumeVersions ResumeVersion[]

  @@index([resumeId])
  @@index([jobPostingId])
}

enum VersionSource {
  ORIGINAL
  AI_OPTIMIZED
  MANUAL_EDIT
  RESTORED
}

model ResumeVersion {
  id                    String        @id @default(cuid())
  resumeId              String
  jobPostingId          String?
  analysisId            String?
  restoredFromVersionId String?
  source                VersionSource @default(ORIGINAL)
  customLabel           String?
  isOriginal            Boolean       @default(false)
  structuredData        Json
  presentation          Json?
  atsScore              Int?
  matchScore            Int?
  createdAt             DateTime      @default(now())

  resume       Resume          @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobPosting   JobPosting?     @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  analysis     AIAnalysis?     @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  restoredFrom ResumeVersion?  @relation("VersionRestore", fields: [restoredFromVersionId], references: [id], onDelete: SetNull)
  restoredInto ResumeVersion[] @relation("VersionRestore")
  applications Application[]

  @@index([resumeId])
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
}

model Application {
  id              String            @id @default(cuid())
  userId          String
  resumeId        String
  resumeVersionId String?
  jobPostingId    String?
  company         String
  jobTitle        String
  status          ApplicationStatus @default(SAVED)
  appliedDate     DateTime?
  interviewDate   DateTime?
  followUpDate    DateTime?
  notes           String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume        Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeVersion ResumeVersion? @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)
  jobPosting    JobPosting?    @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}
